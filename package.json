{
  "name": "ad-app-deploy-manager",
  "version": "1.0.0",
  "description": "Active Directory App Deployment Manager - Drop & Run GPO System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win --dir",
    "build:legacy": "npx electron-packager . \"AD_Deploy_Manager\" --platform=win32 --arch=x64 --electron-version=33.0.0 --out=dist --overwrite"
  },
  "build": {
    "appId": "com.omnisec.appdeploymanager",
    "productName": "AppDeploy Manager",
    "directories": {
      "output": "dist_portable",
      "buildResources": "img"
    },
    "compression": "maximum",
    "asar": true,
    "electronLanguages": ["es", "en-US"],
    "files": [
      "main.js",
      "preload.js",
      "services/**/*",
      "renderer/**/*",
      "img/**/*",
      "LICENSE",
      "!**/*.md",
      "!**/*.map",
      "!**/.DS_Store",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!.editorconfig",
      "!.git",
      "!dist/${/*}",
      "!dist_portable/${/*}"
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "AppDeployManager-Portable.exe"
    }
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
