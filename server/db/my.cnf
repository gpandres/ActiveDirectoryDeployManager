[mysqld]
# Tuned for a log ingestion workload: write-heavy, append-only,
# few concurrent readers (dashboards). Assumes ~2 GB RAM for the
# container. Scale buffer_pool if you give it more.

character-set-server      = utf8mb4
collation-server          = utf8mb4_unicode_ci
default-time-zone         = '+00:00'

# ── Connections
max_connections           = 200
max_allowed_packet        = 16M
thread_cache_size         = 32

# ── InnoDB (bulk of the perf budget)
innodb_buffer_pool_size   = 1G
innodb_log_file_size      = 256M
innodb_flush_log_at_trx_commit = 2   # trade tiny durability for 5x faster inserts
innodb_flush_method       = O_DIRECT
innodb_file_per_table     = 1
innodb_stats_on_metadata  = 0

# ── Binary log off by default (no replication here; saves disk)
skip-log-bin

# ── Slow query log to stderr for docker logs visibility
slow_query_log            = 1
long_query_time           = 1
log_output                = FILE
slow_query_log_file       = /var/log/mysql/slow.log

# ── Misc
sql_mode                  = STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION
event_scheduler           = ON
