# Reverse proxy + automatic TLS for the API.
#
# Replace "logs.empresa.local" with your real hostname. If you use
# an internal CA, drop `tls internal` and mount your cert/key.

logs.empresa.local {
    encode zstd gzip

    # Strict security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
        -Server
    }

    # Only proxy API paths; everything else gets a 404.
    handle /api/* {
        reverse_proxy api:8080
    }
    handle /health {
        reverse_proxy api:8080
    }
    handle {
        respond 404
    }

    tls internal
}
