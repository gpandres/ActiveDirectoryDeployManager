# Reverse proxy + automatic TLS for the API.
#
# Hostname is provided via the LOG_HOSTNAME environment variable
# (set in docker-compose.yml or .env). `tls internal` makes Caddy
# issue a certificate from its own internal CA; the CA root lives
# in the caddy_data volume. Clients must trust that root OR use
# certificate pinning via the `tlsFingerprint` field.

{$LOG_HOSTNAME} {
    encode zstd gzip

    # Strict security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
        -Server
    }

    # Proxy API and the small admin console; everything else gets a 404.
    handle /api/* {
        reverse_proxy api:8080
    }
    handle /admin* {
        reverse_proxy api:8080
    }
    handle /health {
        reverse_proxy api:8080
    }
    handle {
        respond 404
    }

    tls internal
}
