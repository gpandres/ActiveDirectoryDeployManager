# Reverse proxy + automatic TLS for the API.
#
# `tls internal` makes Caddy issue a certificate from its own
# internal CA; the CA root lives in the caddy_data volume. Clients
# must trust that root OR use certificate pinning (the app does
# that via the `tlsFingerprint` field in the share config).

reposrv.superexport.local {
    encode zstd gzip

    # Strict security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "no-referrer"
        -Server
    }

    # Only proxy API paths; everything else gets a 404.
    handle /api/* {
        reverse_proxy api:8080
    }
    handle /health {
        reverse_proxy api:8080
    }
    handle {
        respond 404
    }

    tls internal
}
